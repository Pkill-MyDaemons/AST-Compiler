@cli.command("skeleton")
@click.argument("ast_file", type=click.Path(exists=True))
@click.option("--pretty/--no-pretty", default=True)
def cmd_skeleton(ast_file, pretty):
    """Print names and signatures only (no bodies)."""
    module = load(ast_file)
    click.echo(json.dumps(build_skeleton(module), indent=2 if pretty else None, ensure_ascii=False))


@cli.command("get")
@click.argument("ast_file", type=click.Path(exists=True))
@click.argument("node_id")
@click.option("--pretty/--no-pretty", default=True)
def cmd_get(ast_file, node_id, pretty):
    """Print the full content of a node."""
    try:
        module = load(ast_file)
        node = get_node(module, node_id)
    except ValueError as e:
        click.echo(f"Error: {e}", err=True)
        sys.exit(1)
    click.echo(json.dumps(node, indent=2 if pretty else None, ensure_ascii=False))


@cli.command("str-replace")
@click.argument("ast_file", type=click.Path(exists=True))
@click.argument("node_id")
@click.argument("old_stmt_json")
@click.argument("new_stmt_json")
def cmd_str_replace(ast_file, node_id, old_stmt_json, new_stmt_json):
    """Replace a statement in a function body."""
    try:
        module = load(ast_file)
        str_replace_body(module, node_id, _maybe_read_file(old_stmt_json), _maybe_read_file(new_stmt_json))
        save(module, ast_file)
        click.echo(f"Replaced statement in {node_id}", err=True)
    except ValueError as e:
        click.echo(f"Error: {e}", err=True)
        sys.exit(1)


